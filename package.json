{
  "name": "budget-bitch",
  "productName": "Budget Bitch!",
  "private": true,
  "version": "1.1.2",
  "description": "A private, local-first statement and budgeting app.",
  "main": "electron/main.mjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "electron .",
    "desktop:pack": "electron-builder --mac dir",
    "desktop:dmg": "electron-builder --mac dmg"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "chart.js": "^4.4.9",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.2",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.3.1",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "build": {
    "appId": "au.com.budgetbitch.app",
    "productName": "Budget Bitch!",
    "afterPack": "electron/after-pack.mjs",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "scripts/**/*",
      "src/**/*",
      "index.html",
      "vite.config.js",
      "package.json",
      "!**/.data/**",
      "!dist/**",
      "!release/**"
    ],
    "mac": {
      "category": "public.app-category.finance",
      "target": [
        "dir",
        "dmg"
      ]
    },
    "artifactName": "Budget-Bitch-${version}-${arch}.${ext}"
  }
}
